# ── Supabase ────────────────────────────────────────────────────────────────
# Encontre em: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Chave de serviço (apenas para o dashboard admin — nunca expor ao cliente)
# Encontre em: Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ── Acesso ao Dashboard ──────────────────────────────────────────────────────
# E-mail do organizador que terá acesso a /dashboard
NEXT_PUBLIC_OWNER_EMAIL=seu@email.com
